# Copy to /etc/pontaj/pontaj.env (mode 0640 root:pontaj), then edit.
DJANGO_ENV=production
DEBUG=False

# Set this to your real domain(s)
ALLOWED_HOSTS=example.com

# CORS (recommended: specify exact origins)
# CORS_ALLOW_ALL_ORIGINS=False
# CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# Secrets
SECRET_KEY=change-me

# Database (recommended)
DATABASE_URL=postgresql://pontaj:change-me@127.0.0.1:5432/pontaj

# Static/media outside the repo (recommended)
STATIC_ROOT=/srv/pontaj/static
MEDIA_ROOT=/srv/pontaj/media

# If you terminate TLS at Nginx, set these:
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# CSRF_TRUSTED_ORIGINS=https://example.com
